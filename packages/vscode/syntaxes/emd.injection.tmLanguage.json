{
  "scopeName": "template.injection.emd",
  "injectionSelector": "L:text.html.markdown, L:source.emd",
  "patterns": [
    {
      "name": "meta.template.emd",
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template.begin.emd" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.template.end.emd" }
      },
      "patterns": [
        {
          "name": "variable.other.emd",
          "match": "."
        }
      ]
    },
    {
      "name": "allowed.backslash",
      "patterns": [
        {
          "name": "constant.character.escape.emd",
          "match": "(?<!\\\\)(\\\\[\\\\`'\"*_{}\\[\\]()#+.!|<>\\/&$~^=:nrst-])+"
        }
      ]
    }
  ]
}
