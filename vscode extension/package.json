{
  "name": "extendedmd",
  "displayName": "ExtendedMD",
  "description": "Extending Markdown, allowing you to create dynamic and reusable content within your Markdown files.",
  "version": "0.0.1",
  "author": {
    "name": "Roei Meiri"
  },
  "license": "MIT",
  "icon": "icons/extendedmd.png",
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "emd",
        "aliases": [
          "ExtendedMarkdown",
          "ExtendedMD",
          "EMD",
          "emd"
        ],
        "extensions": [
          ".emd"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/extendedmd.svg",
          "dark": "./icons/extendedmd.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "emd",
        "scopeName": "source.emd",
        "path": "./syntaxes/emd.tmLanguage.json"
      },
      {
        "scopeName": "template.injection.emd",
        "path": "./syntaxes/emd.injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown",
          "source.emd"
        ]
      }
    ],
    "fileIconThemes": [
      {
        "id": "extendedmd-icons",
        "label": "ExtendedMD File Icon",
        "path": "./icons/theme.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:emd"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/RoeiMeiri9/extendedmd"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.106.1",
    "typescript": "^5.9.3",
    "vscode": "^1.1.37"
  }
}
