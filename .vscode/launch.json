{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/packages/vscode"],
      "outFiles": ["${workspaceFolder}/packages/vscode/out/**/*.js"]
    },
    {
      "name": "Debug CLI",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/cli",
      "program": "${workspaceFolder}/packages/cli/dist/index.js",
      "args": ["--watch", "../../tests/readme.emd"],
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/packages/cli/dist/**/*.js"]
    }
  ]
}
